# Vercel only needs the build script + the reports it will package into dist/.
# Everything else stays out of the deployment to keep uploads small and avoid
# leaking source / secrets.
# Source code and tests — the scan runs in CI, not on Vercel.
src/
tests/
performance/
test-data/
docs/
playwright.config.ts
playwright/
# CI / tooling — not needed at deploy time.
.github/
.gitlab-ci.yml
Jenkinsfile
lighthouserc.json
# Dev artifacts.
node_modules/
.auth/
test-results/
playwright/.cache/
# Local environment — must never ship.
.env
.env.*
!.env.example
# Build output is regenerated by `vercel build`.
dist/
.vercel/
# Editor / OS noise.
.DS_Store
.idea/
.vscode/
# Anything starting with a dot at the top level we don't already list.
# (Vercel's default already excludes most of these but be explicit.)
*.log