{
  "name": "ai-website-validation-platform",
  "version": "1.0.0",
  "private": true,
  "description": "Enterprise-grade AI website validation platform for Sportstech.",
  "type": "module",
  "scripts": {
    "scan": "tsx src/cli/runScan.ts tests/regression",
    "scan:smoke": "QUICK_SCAN=1 MAX_PAGES=1 DEVICE_SET=desktop BROWSERS=chromium REQUEST_TIMEOUT_MS=12000 MAX_LINK_CHECKS=3 MAX_CONTROL_CHECKS=5 tsx src/cli/runScan.ts tests/regression",
    "scan:demo": "tsx src/cli/runDemoScan.ts",
    "test:smoke": "playwright test tests/smoke",
    "test:seo": "playwright test tests/seo",
    "test:security": "playwright test tests/security",
    "test:performance": "BROWSERS=chromium playwright test tests/performance",
    "test:a11y": "playwright test tests/accessibility",
    "test:visual": "BROWSERS=chromium playwright test tests/visual",
    "test:visual:update": "BROWSERS=chromium playwright test tests/visual --update-snapshots",
    "test:all-suites": "playwright test tests/exploration tests/smoke tests/seo tests/security tests/performance tests/accessibility",
    "test:explore": "BROWSERS=chromium playwright test tests/exploration",
    "test:explore:headed": "BROWSERS=chromium playwright test tests/exploration --headed",
    "test:everything": "playwright test tests/exploration tests/smoke tests/seo tests/security tests/performance tests/accessibility tests/visual; npm run report:suites",
    "report:suites": "tsx src/cli/buildSuiteReport.ts",
    "report:share": "tsx src/cli/shareReport.ts",
    "report:share:full": "tsx src/cli/shareReport.ts --full",
    "report:share:zip": "tsx src/cli/shareReport.ts --zip",
    "test:smoke:headed": "playwright test tests/smoke --headed",
    "test:seo:headed": "playwright test tests/seo --headed",
    "test:security:headed": "playwright test tests/security --headed",
    "test:performance:headed": "BROWSERS=chromium playwright test tests/performance --headed",
    "test:a11y:headed": "playwright test tests/accessibility --headed",
    "test:visual:headed": "BROWSERS=chromium playwright test tests/visual --headed",
    "test:visual:update:headed": "BROWSERS=chromium playwright test tests/visual --update-snapshots --headed",
    "test:everything:headed": "playwright test tests/exploration tests/smoke tests/seo tests/security tests/performance tests/accessibility tests/visual --headed; npm run report:suites",
    "auth:login": "tsx src/cli/setupAuth.ts",
    "auth:login:headed": "HEADED=1 tsx src/cli/setupAuth.ts",
    "ai:generate-specs": "tsx src/cli/generateSpecs.ts",
    "queue:enqueue": "tsx src/cli/queueEnqueue.ts",
    "queue:work": "tsx src/cli/queueWorker.ts",
    "lhci": "lhci autorun",
    "discover": "tsx src/discovery/runDiscovery.ts",
    "lighthouse": "tsx src/lighthouse/runLighthouse.ts",
    "pdf": "tsx src/reports/renderPdf.ts",
    "report": "tsx src/reports/openReport.ts",
    "report:playwright": "npx playwright show-report reports/playwright-report",
    "k6": "k6 run performance/k6-load-test.js",
    "typecheck": "tsc --noEmit",
    "test:unit": "node --import tsx --test tests/unit/*.test.ts"
  },
  "keywords": [
    "playwright",
    "qa",
    "seo",
    "accessibility",
    "lighthouse",
    "k6"
  ],
  "dependencies": {
    "tsx": "^4.19.4"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@playwright/test": "^1.52.0",
    "@types/node": "^22.15.24",
    "chrome-launcher": "^1.1.2",
    "dotenv": "^16.5.0",
    "lighthouse": "^12.6.0",
    "openai": "^4.103.0",
    "typescript": "^5.8.3"
  },
  "optionalDependencies": {
    "bullmq": "^5.0.0",
    "ioredis": "^5.4.0"
  }
}
