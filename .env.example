# Target
BASE_URL=https://www.sportstech.de/
MAX_PAGES=50
CRAWL_DEPTH=4
SUITE_MAX_PAGES=15
IGNORED_PATHS=/cart,/checkout,/account,/wp-admin,/logout

# Discovery seeds & scale
SEED_SITEMAP=auto            # auto = <origin>/sitemap.xml | explicit URL | off
SEED_URLS=                   # comma-separated extra start URLs
CRAWL_CONCURRENCY=4          # parallel crawl tabs
INCREMENTAL=0                # 1 = validate only pages changed since last crawl

# Speed: scroll waits are already trimmed. Runs serial (one browser at a time) by default.
# Set WORKERS=4 only if your machine can handle parallel browsers (can hang on headed runs).
WORKERS=
MAX_RECHECKS=15               # cap confidence re-validations per page

# Mandatory page exploration — full TOP→BOTTOM→TOP scroll before testing (SCROLL_ENGINE=0 disables)
SCROLL_ENGINE=1
SCROLL_STEP_FRACTION=0.9       # viewport fraction scrolled per step (bigger = fewer steps)
SCROLL_MAX_STEPS=30
SCROLL_STEP_DELAY_MS=          # dwell per step (default 160ms, 70ms in FAST_MODE)
SCROLL_BOTTOM_DWELL_MS=        # bottom wait (default 1500ms, 600ms in FAST_MODE)
SCROLL_TOP_DWELL_MS=           # stabilize at top (default 350ms, 150ms in FAST_MODE)
SCROLL_MAX_INTERACTIONS=3

# Overlay auto-dismiss retry schedule (ms after each navigation)
OVERLAY_RETRY_MS=600,2500,5000,8000

# False-positive reduction
CONFIDENCE_THRESHOLD=60      # issues below this % are downgraded to info

# Authentication (credentials stay in .env — never commit)
AUTH_MODE=none               # none | form | storage | custom (OAuth/SSO hook)
AUTH_LOGIN_URL=
AUTH_USERNAME=
AUTH_PASSWORD=
AUTH_USERNAME_SELECTOR=
AUTH_PASSWORD_SELECTOR=
AUTH_SUBMIT_SELECTOR=
AUTH_SUCCESS_URL_PATTERN=
AUTH_STORAGE_PATH=.auth/storage-state.json

# Execution
DEVICE_SET=all
BROWSERS=chromium,firefox,webkit
WORKERS=1
RETRIES=0
TEST_TAGS=
LOG_LEVEL=info

# Performance budgets (ms / KB / unitless CLS)
BUDGET_LCP_MS=2500
BUDGET_FCP_MS=1800
BUDGET_CLS=0.1
BUDGET_TBT_MS=300
BUDGET_LOAD_MS=5000
BUDGET_TRANSFER_KB=3000
SLOW_REQUEST_MS=2000

# Analytics import (CSV or JSON export from GA4 / Search Console / server logs)
ANALYTICS_DATA_PATH=test-data/analytics.csv

# AI analyzer — set one key; AI_PROVIDER auto-detects (anthropic|openai|none)
AI_PROVIDER=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
